<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Terminal Troubleshooting Lab</title>
  <link rel="icon" type="image/svg+xml" href="./favicon.svg">
  <link rel="stylesheet" href="./style.css?v=20260506hub2">
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2" defer></script>
  <script src="./supabase-config.js?v=20260421sup1" defer></script>
  <script src="./app-data.js?v=20260510ports1" defer></script>
  <script src="./mascot.js?v=20260509patchgap1" defer></script>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>
  <script src="./index.js?v=20260506hub2" defer></script>
</head>
<body>
  <div class="rack-room">
    <div class="router-shell">
      <div class="router-top">
        <div class="router-brand">NET-LAB TERMINAL DESK</div>
        <div class="router-leds" aria-hidden="true">
          <span class="led led-green led-blink"></span>
          <span class="led led-yellow led-blink-slow"></span>
          <span class="led led-green"></span>
          <span class="led led-red"></span>
        </div>
      </div>

      <h1>Terminal Troubleshooting Lab</h1>

      <section class="hub-page-top">
        <section id="hubResumePanel" class="hub-hero-panel">
          <div class="hub-hero-content">
            <div class="hub-hero-copy-block">
              <h2>Practise terminal troubleshooting in your browser.</h2>
              <p class="hub-hero-copy">Guided terminal labs for Windows, Linux, Cisco, cyber, and networking basics.</p>
              <div class="hub-hero-actions">
                <a class="app-action-btn hub-hero-action-primary" href="./terminal-coach.html?track=windows&amp;mode=beginner" title="Start Beginner Terminal Lab" aria-label="Start Beginner Terminal Lab">Start</a>
                <div id="hubResumeActions" class="hub-resume-actions" hidden></div>
              </div>
            </div>
            <aside class="mascot-card mascot-card--hero" aria-label="Patch, the beginner IT guide">
              <img class="mascot mascot--hero" src="./assets/mascot/patch-main.png" alt="Patch, the beginner IT guide">
              <p class="mascot-message">Learn practical IT skills by doing.</p>
            </aside>
          </div>
        </section>
      </section>

      <div id="hubResumeModal" class="hub-resume-modal" role="dialog" aria-modal="true" aria-labelledby="hubResumeModalTitle" hidden>
        <button id="hubResumeModalBackdrop" class="hub-resume-modal-backdrop" type="button" aria-label="Close resume details"></button>
        <div class="hub-resume-modal-shell">
          <div class="hub-resume-modal-head">
            <div>
              <p class="app-shell-kicker">Last Activity</p>
              <h2 id="hubResumeModalTitle">Continue Where You Left Off</h2>
            </div>
            <button id="hubResumeModalClose" class="hub-resume-modal-close" type="button" aria-label="Close resume details">Close</button>
          </div>
          <p id="hubResumeModalCopy" class="hub-resume-modal-copy"></p>
          <div class="app-shell-actions hub-resume-modal-actions">
            <a id="hubResumeContinue" class="app-action-link" href="./index.html">Continue</a>
            <button id="hubResumeModalCancel" class="app-action-btn app-action-btn-muted" type="button">Cancel</button>
          </div>
        </div>
      </div>

      <section id="practiceSection">
        <section id="learningPathsPanel" class="learning-paths-panel learning-hub-panel">
          <div class="learning-paths-head">
            <h3>Terminal Labs</h3>
          </div>

          <div class="learning-path-grid learning-path-grid-terminal">
            <a class="learning-path-card learning-path-card-featured learning-path-card-windows" data-section-id="windows-terminal" href="./terminal-coach.html?track=windows&amp;mode=beginner" title="Beginner Lab: guided Windows CMD tickets, walkthroughs, and practical tasks." aria-label="Beginner Lab">
              <span class="learning-path-icon" aria-hidden="true"><i data-lucide="terminal"></i></span>
              <span class="learning-path-kicker">Recommended</span>
              <span class="learning-path-title">Beginner Lab</span>
              <span class="learning-path-status" data-progress-slot="windows-terminal">Not Started</span>
              <span class="learning-path-tooltip" role="tooltip">Guided Windows CMD tickets, walkthroughs, and practical tasks.</span>
            </a>

            <a class="learning-path-card learning-path-card-windows" href="./beginner-roadmap.html" title="Roadmap: view levels, saved progress, and your next beginner task." aria-label="Roadmap">
              <span class="learning-path-icon" aria-hidden="true"><i data-lucide="map"></i></span>
              <span class="learning-path-kicker">Roadmap</span>
              <span class="learning-path-title">Roadmap</span>
              <span class="learning-path-status">Open</span>
              <span class="learning-path-tooltip" role="tooltip">View levels, saved progress, and your next beginner task.</span>
            </a>

            <a class="learning-path-card learning-path-card-linux" data-section-id="linux-terminal" href="./terminal-coach.html?track=linux" title="Linux Lab: practise commands, files, logs, and service checks." aria-label="Linux Lab">
              <span class="learning-path-icon" aria-hidden="true"><i data-lucide="server"></i></span>
              <span class="learning-path-kicker">Linux</span>
              <span class="learning-path-title">Linux Lab</span>
              <span class="learning-path-status" data-progress-slot="linux-terminal">Not Started</span>
              <span class="learning-path-tooltip" role="tooltip">Practise commands, files, logs, and service checks.</span>
            </a>

            <a class="learning-path-card learning-path-card-cisco" data-section-id="cisco-cli" href="./cisco-cli-lab.html" title="Cisco Lab: practise router CLI basics, verification, and recovery workflows." aria-label="Cisco Lab">
              <span class="learning-path-icon" aria-hidden="true"><i data-lucide="router"></i></span>
              <span class="learning-path-kicker">Cisco</span>
              <span class="learning-path-title">Cisco Lab</span>
              <span class="learning-path-status" data-progress-slot="cisco-cli">Not Started</span>
              <span class="learning-path-tooltip" role="tooltip">Practise router CLI basics, verification, and recovery workflows.</span>
            </a>

            <a class="learning-path-card learning-path-card-challenge" data-section-id="cyber-challenge" href="./challenge-mode.html" title="Cyber Mode: investigate evidence, users, processes, and suspicious activity." aria-label="Cyber Mode">
              <span class="learning-path-icon" aria-hidden="true"><i data-lucide="shield-alert"></i></span>
              <span class="learning-path-kicker">Cyber</span>
              <span class="learning-path-title">Cyber Mode</span>
              <span class="learning-path-status" data-progress-slot="cyber-challenge">Not Started</span>
              <span class="learning-path-tooltip" role="tooltip">Investigate evidence, users, processes, and suspicious activity.</span>
            </a>
          </div>
        </section>

        <section class="learning-paths-panel learning-hub-panel reference-labs-panel">
          <div class="learning-paths-head">
            <h3>Supporting Concepts</h3>
            <p>Quick reference labs for networking concepts.</p>
          </div>

          <div class="learning-path-grid learning-path-grid-reference">
            <a class="learning-path-card learning-path-card-reference learning-path-card-subnetting" data-section-id="subnetting-lab" href="./subnetting-lab.html" title="Subnetting Lab: CIDR, masks, ranges, and subnet drills." aria-label="Subnetting Lab">
              <span class="learning-path-icon" aria-hidden="true"><i data-lucide="binary"></i></span>
              <span class="learning-path-kicker">Reference</span>
              <span class="learning-path-title">Subnetting</span>
              <span class="learning-path-status" data-progress-slot="subnetting-lab">Not Started</span>
              <span class="learning-path-tooltip" role="tooltip">CIDR, masks, ranges, and subnet drills.</span>
            </a>

            <a class="learning-path-card learning-path-card-reference learning-path-card-ports" data-section-id="network-ports-lab" href="./network-ports-lab.html" title="Ports Lab: TCP, UDP, listening services, ranges, and exposure risks." aria-label="Network Ports Lab">
              <span class="learning-path-icon" aria-hidden="true"><i data-lucide="cable"></i></span>
              <span class="learning-path-kicker">Ports</span>
              <span class="learning-path-title">Ports</span>
              <span class="learning-path-status" data-progress-slot="network-ports-lab">Not Started</span>
              <span class="learning-path-tooltip" role="tooltip">TCP, UDP, services, ranges, and exposure risks.</span>
            </a>

            <a class="learning-path-card learning-path-card-reference learning-path-card-web" data-section-id="web-http-lab" href="./web-http-lab.html" title="HTTP Lab: requests, responses, sessions, and proxy basics." aria-label="HTTP Reference Lab">
              <span class="learning-path-icon" aria-hidden="true"><i data-lucide="globe"></i></span>
              <span class="learning-path-kicker">Web</span>
              <span class="learning-path-title">HTTP</span>
              <span class="learning-path-status" data-progress-slot="web-http-lab">Not Started</span>
              <span class="learning-path-tooltip" role="tooltip">Requests, responses, sessions, and proxy basics.</span>
            </a>

            <a class="learning-path-card learning-path-card-reference learning-path-card-protocol" data-section-id="protocol-lab" href="./protocol-merge.html" title="ARP Lab: ARP and protocol flow reference." aria-label="ARP Reference Lab">
              <span class="learning-path-icon" aria-hidden="true"><i data-lucide="route"></i></span>
              <span class="learning-path-kicker">Protocol</span>
              <span class="learning-path-title">ARP</span>
              <span class="learning-path-status" data-progress-slot="protocol-lab">Not Started</span>
              <span class="learning-path-tooltip" role="tooltip">ARP and protocol flow reference.</span>
            </a>
          </div>
        </section>
      </section>

      <div class="router-ports" aria-hidden="true">
        <div class="port connected"><span class="cable"></span></div>
        <div class="port connected"><span class="cable cable-green"></span></div>
        <div class="port"></div>
        <div class="port active"></div>
        <div class="port connected"><span class="cable cable-yellow"></span></div>
        <div class="port"></div>
        <div class="port active"></div>
        <div class="port"></div>
      </div>
    </div>
  </div>
  <script>
    window.addEventListener("DOMContentLoaded", function () {
      if (window.lucide) {
        window.lucide.createIcons();
      }
    });
  </script>
</body>
</html>
